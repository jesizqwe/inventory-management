# Server environment variables
DATABASE_URL=postgresql://user:password@host:5432/dbname
JWT_SECRET=your-super-secret-jwt-key
PORT=3000
ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-app-123.vercel.app

# OAuth credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://inventory-management-51zr.onrender.com/auth/google/callback

GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=https://inventory-management-51zr.onrender.com/auth/github/callback

# File storage (optional)
BUCKET_NAME=your-bucket-name
BUCKET_REGION=your-bucket-region
BUCKET_ACCESS_KEY=your-access-key
BUCKET_SECRET_KEY=your-secret-key
